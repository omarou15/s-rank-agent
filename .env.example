# ═══════════════════════════════════════════
# S-RANK AGENT — Environment Variables
# ═══════════════════════════════════════════
# Copy this file to .env and fill in the values
# NEVER commit .env to git

# ── Auth (Clerk) ──
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/signup
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/chat
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# ── Database (Neon PostgreSQL) ──
DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/srank?sslmode=require

# ── Redis (Upstash) ──
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxx

# ── Hetzner Cloud (Server Provisioning) ──
HETZNER_API_TOKEN=xxx
HETZNER_SSH_KEY_NAME=s-rank-agent
HETZNER_FIREWALL_ID=xxx

# ── Stripe (Billing) ──
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_STARTER_PRICE_ID=price_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_BUSINESS_PRICE_ID=price_...

# ── Encryption ──
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your-32-byte-hex-key-here

# ── API URLs ──
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:4000

# ── Monitoring ──
SENTRY_DSN=https://xxx@sentry.io/xxx
NEXT_PUBLIC_SENTRY_DSN=https://xxx@sentry.io/xxx

# ── App ──
NODE_ENV=development
PORT=4000
