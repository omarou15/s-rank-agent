{
  "name": "@s-rank/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format esm --dts",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "hono": "^4.4.0",
    "@hono/node-server": "^1.11.0",
    "drizzle-orm": "^0.30.0",
    "@neondatabase/serverless": "^0.9.0",
    "@upstash/redis": "^1.31.0",
    "@upstash/ratelimit": "^1.1.0",
    "@clerk/backend": "^1.2.0",
    "socket.io": "^4.7.0",
    "ssh2": "^1.15.0",
    "stripe": "^15.0.0",
    "zod": "^3.22.0",
    "nanoid": "^5.0.0",
    "@s-rank/shared": "workspace:*"
  },
  "devDependencies": {
    "tsx": "^4.7.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0",
    "drizzle-kit": "^0.21.0",
    "@types/ssh2": "^1.15.0"
  }
}
